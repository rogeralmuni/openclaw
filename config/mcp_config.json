{
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-notion"],
      "env": {
        "NOTION_TOKEN": "{{NOTION_TOKEN}}"
      }
    },
    "attio": {
      "command": "npx",
      "args": ["-y", "@attio/mcp-server"],
      "env": {
        "ATTIO_TOKEN": "{{ATTIO_TOKEN}}"
      }
    },
    "google-maps": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-maps"],
      "env": {
        "GOOGLE_MAPS_API_KEY": "{{GOOGLE_MAPS_API_KEY}}"
      }
    }
  }
}
